# 智研 SaaS 版 — 環境設定
# 複製此檔為 .env 並填入你的 API 金鑰
#
# ⚠️  APP_SECRET_KEY 必須在正式部署前替換為隨機強金鑰
# 產生方式（擇一）：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   openssl rand -base64 48

# LLM API 設定 (支援 OpenAI 相容 API)
ZHIYAN_API_KEY=sk-your-api-key-here
ZHIYAN_API_BASE_URL=https://api.openai.com/v1
ZHIYAN_MODEL=gpt-4o

# 應用設定
APP_SECRET_KEY=REPLACE_WITH_RANDOM_SECRET_HERE
APP_PORT=8000
APP_HOST=0.0.0.0

# 若使用 DeepSeek（預設）
# ZHIYAN_API_BASE_URL=https://api.deepseek.com/v1
# ZHIYAN_MODEL=deepseek-chat

# 若使用 OpenRouter
# ZHIYAN_API_BASE_URL=https://openrouter.ai/api/v1
# ZHIYAN_MODEL=anthropic/claude-3.5-sonnet
