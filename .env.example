# ═══════════════════════════════════════════════════════════════════
# 智研AI法律工作站 — Zhiyan AI Legal System
# Provider-agnostic configuration
#
# Copy this file to .env and fill in your preferred provider.
#
# ── MAIN OPTIONS (pick ONE provider) ────────────────────────────────

# 統一設定範本 v3.9.3
#
# 複製此檔為 .env，填入你的金鑰即可帶動整個系統。
# 所有子系統（主引擎、合議庭、benchmark）均從此讀取。
#
# ── 主引擎：選一個 provider 取消註解 ──────────────────────────────

# Option A: OpenAI
ZHIYAN_API_KEY=your-openai-key-here
ZHIYAN_API_BASE_URL=https://api.openai.com/v1
ZHIYAN_MODEL=gpt-5.1

# Option B: OpenRouter (access 400+ models)
# ZHIYAN_API_KEY=sk-or-...
# ZHIYAN_API_BASE_URL=https://openrouter.ai/api/v1
# ZHIYAN_MODEL=anthropic/claude-sonnet-4.6

# Option C: DeepSeek V4
# ZHIYAN_API_KEY=sk-...
# ZHIYAN_API_BASE_URL=https://api.deepseek.com
# ZHIYAN_MODEL=deepseek/deepseek-v4-flash

# Option D: Google Gemini (OpenAI-compatible endpoint)
# ZHIYAN_API_KEY=AIza...
# ZHIYAN_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# ZHIYAN_MODEL=gemini-3-flash-preview

# Option E: MiniMax M3 (cost-effective, strong in legal domain)

ZHIYAN_MODEL=gpt-4o-mini

# Option B: OpenRouter（支援 400+ 模型）
# ZHIYAN_API_KEY=sk-or-...
# ZHIYAN_API_BASE_URL=https://openrouter.ai/api/v1
# ZHIYAN_MODEL=anthropic/claude-sonnet-4-5

# Option C: DeepSeek
# ZHIYAN_API_KEY=sk-...
# ZHIYAN_API_BASE_URL=https://api.deepseek.com
# ZHIYAN_MODEL=deepseek-chat

# Option D: Google Gemini（OpenAI-compatible）
# ZHIYAN_API_KEY=AIza...
# ZHIYAN_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# ZHIYAN_MODEL=gemini-2.5-flash

# Option E: MiniMax M3
# ZHIYAN_API_KEY=your-key-here
# ZHIYAN_API_BASE_URL=https://api.minimax.chat/v1
# ZHIYAN_MODEL=minimax-m3

# Option F: NVIDIA Nemotron 3 Super (free, rate-limited)
# ZHIYAN_API_KEY=...
# ZHIYAN_API_BASE_URL=https://api.nvidia.com/v1
# ZHIYAN_MODEL=nvidia/nemotron-3-super

# ═══════════════════════════════════════════════════════════════════
# (Optional) Environment auto-detection
# If ZHIYAN_API_KEY is not set, the runner will try these fallbacks:
#   OPENAI_API_KEY
#   OPENROUTER_API_KEY
#   GEMINI_API_KEY
#   GOOGLE_API_KEY
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# (Optional) Custom docs directory (if docs/ is not at repo root)
# ZHIYAN_DOCS_DIR=/path/to/zhiyan-legal/docs
# ═══════════════════════════════════════════════════════════════════

# ── OPTIONAL: Output controls ─────────────────────────────────────
# ZHIYAN_TEMPERATURE=0.3
# ZHIYAN_MAX_TOKENS=4096

# Option F: NVIDIA Nemotron（免費，有限速）
# ZHIYAN_API_KEY=...
# ZHIYAN_API_BASE_URL=https://integrate.api.nvidia.com/v1
# ZHIYAN_MODEL=nvidia/nemotron-3-super

# ── 合議庭（多模型合議，非必填）──────────────────────────────────────
# Agnes AI — 合議庭主力，兩把金鑰做 429 輪換
AGNES_API_KEY_1=your-agnes-key-1
AGNES_API_KEY_2=your-agnes-key-2
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash

# Gemini — 合議庭第三席（使用原生 SDK）
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ── 輸出調控（選填）──────────────────────────────────────────────
# ZHIYAN_TEMPERATURE=0.3
# ZHIYAN_MAX_TOKENS=4096

# ── 路徑覆寫（通常不需要改）──────────────────────────────────────
# ZHIYAN_DOCS_DIR=/path/to/zhiyan-legal/docs
# ZHIYAN_SKILL_DIR=/path/to/.hermes/skills/openclaw-imports/zhiyan-legal
# ZHIYAN_DB_PATH=/path/to/zhiyan-legal/data/laws.db

# ── 系統行為 ────────────────────────────────────────────────────
# ZHIYAN_LOG_LEVEL=INFO        # DEBUG / INFO / WARNING / ERROR
# ZHIYAN_DRY_RUN=false         # true = 不送 API，只印 prompt
# ZHIYAN_DEBUG=false

# ═══════════════════════════════════════════════════════════════════
# 自動 fallback 順序（當 ZHIYAN_API_KEY 未設定時）：
#   OPENAI_API_KEY → OPENROUTER_API_KEY → GEMINI_API_KEY → GOOGLE_API_KEY
# ═══════════════════════════════════════════════════════════════════
